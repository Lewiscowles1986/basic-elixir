{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker-compose up -d",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Docker Compose Build",
      "type": "shell",
      "command": "docker-compose build",
      "group": "build"
    },
    {
      "label": "Run Tests (Docker)",
      "type": "shell",
      "command": "docker-compose run --rm web mix test",
      "group": "test"
    },
    {
      "label": "Ecto Setup (Docker)",
      "type": "shell",
      "command": "docker-compose run --rm web mix ecto.setup",
      "group": "build"
    }
  ]
}
